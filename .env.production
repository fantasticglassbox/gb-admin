# Production environment variables
REACT_APP_API_BASE_URL=https://begu.glassbox.id
REACT_APP_ENVIRONMENT=production

# Skip ESLint during prod build. CRA's CI=true treats every warning as an
# error, which makes builds fragile against legacy unused-import / hook-deps
# noise. Editor + dev server still surface these as warnings.
DISABLE_ESLINT_PLUGIN=true
